# ---- Aiva backend configuration ----
# Copy to .env and edit. All values below are defaults.

# Network
HOST=0.0.0.0
PORT=8420

# Auth — CHANGE THIS to a long random string before exposing on your LAN.
API_TOKEN=change-me-aiva-token

# Background dashboard push interval (seconds)
PUSH_INTERVAL_SECONDS=3

# Mock mode: serve plausible fake metrics + canned chat replies (no LLM needed)
MOCK_MODE=false

# CORS. Default ["*"] is convenient for local dev. RESTRICT to your app's
# origin(s) in production, e.g. CORS_ORIGINS=["http://192.168.1.10"]
CORS_ORIGINS=["*"]

# SQLite database file. Default: <repo>/workspace/aiva.db (all user data —
# db, persona, memory — lives in the workspace folder, outside the code).
# DB_PATH=/absolute/path/to/aiva.db

# ---- Chat provider ----
# "litellm" = any model endpoint (below). "cli" = bridge chat to any local
# agent CLI session (Claude Code, Codex, custom script) — see CHAT_CLI_*.
CHAT_PROVIDER=litellm

# ---- litellm provider: ANY model ----
#   Ollama:       LLM_MODEL=ollama/llama3.1                       LLM_API_BASE=http://localhost:11434
#   LM Studio:    LLM_MODEL=openai/local-model                    LLM_API_BASE=http://localhost:1234/v1  LLM_API_KEY=lm-studio
#   OpenRouter:   LLM_MODEL=openrouter/anthropic/claude-sonnet-4-6  (no LLM_API_BASE)  LLM_API_KEY=sk-or-...
#                 ...or openrouter/openai/gpt-4o, openrouter/google/gemini-2.5-pro, openrouter/meta-llama/llama-3.3-70b-instruct, etc.
#   OpenAI:       LLM_MODEL=openai/gpt-4o-mini                     (no LLM_API_BASE)  LLM_API_KEY=sk-...
# IMPORTANT: leave LLM_API_BASE unset/empty for hosted providers like OpenRouter.
LLM_MODEL=ollama/llama3.1
LLM_API_BASE=http://localhost:11434
# LLM_API_KEY=

# ---- cli provider: chat with a local agent session ----
# JSON command templates. {message} = user text, {system} = LLM_SYSTEM_PROMPT.
# CHAT_CLI_CONTINUE_CMD (optional) is used from the 2nd message on, for
# session continuity; on failure it retries fresh with CHAT_CLI_CMD.
# Claude Code recipe:
# CHAT_CLI_CMD=["claude","-p","{message}","--mcp-config","aiva-mcp.json","--allowedTools","mcp__aiva","--append-system-prompt","{system}"]
# CHAT_CLI_CONTINUE_CMD=["claude","-p","{message}","--continue","--mcp-config","aiva-mcp.json","--allowedTools","mcp__aiva","--append-system-prompt","{system}"]
# Codex CLI recipe:
# CHAT_CLI_CMD=["codex","exec","{message}"]
# CHAT_CLI_TIMEOUT=120

LLM_SYSTEM_PROMPT=You are Aiva, a calm, concise local assistant running on the user's Mac. Keep replies short — they render on a 4-inch phone cover screen.

# Services to health-check (JSON list of {name, target, kind:"http"|"tcp"})
SERVICES_JSON=[{"name":"Backend API","target":"http://127.0.0.1:8420/api/health","kind":"http"},{"name":"Ollama","target":"127.0.0.1:11434","kind":"tcp"}]

# Optional static agenda when MOCK_MODE=false (JSON list of {time,title,meta,now})
# AGENDA_JSON=[]

GREETING_NAME=Alex
STORE_CHAT_HISTORY=true


# ---- Agent workspace (persona + memory, OpenClaw-style) ----
# SOUL.md / USER.md define the persona; memory/MEMORY.md + memory/HISTORY.md
# are maintained by the model via the save_memory tool.
# Default: <repo>/workspace. Point it anywhere (e.g. a synced folder).
# WORKSPACE_PATH=/absolute/path/to/workspace
